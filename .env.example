# ───────────────────────────────────────────────
# 健保問い合わせサポートシステム 製品版 設定例
# このファイルを .env にコピーして編集してください（任意）
# ───────────────────────────────────────────────

# 既定のAIプロバイダ: claude / chatgpt / gemini
# 画面右上のセレクタでも切り替え可能（こちらは初期値）
DEFAULT_AI_PROVIDER=claude

# AI応答のタイムアウト秒数
AI_TIMEOUT=120

# 本製品は各AIの「公式CLI」を、利用者ご自身のアカウントで
# ログインして呼び出します。APIキーの設定は不要です。
#   - Claude  : Claude Code CL     `claude`  でログイン
#   - ChatGPT : OpenAI Codex CLI   `codex`   でログイン
#   - Gemini  : Gemini CLI         `gemini`  でログイン
# 詳細は README.md の「導入手順」を参照してください。
